{
    "name": "csvstore",
    "version": "1.0.0",
    "description": "Tool to store csvs from banks and convert them to other formats (currently only Bank Austria as input supported and YNAB as output supported)",
    "main": "index.js",
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "start": "node dist/server.js --env prod",
        "watch": "nodemon --watch dist -e js,css,html,gz --exec 'node dist/server.js --env prod'",
        "devbuild": "gulp dev",
        "build": "gulp",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "author": "Christian Sterzl <christian.sterzl@gmail.com>",
    "repository": "github:waxolunist/bankimporter",
    "license": "ISC",
    "dependencies": {
        "datauri": "^1.1.0",
        "db-migrate": "^0.11.1",
        "db-migrate-sqlite3": "^1.0.0",
        "memorystream": "^0.3.1",
        "mime-types": "^2.1.18",
        "moment": "^2.21.0",
        "moment-timezone": "^0.5.14",
        "numeral": "^2.0.6",
        "object-hash": "^1.3.0",
        "puppeteer": "^22.0.0",
        "sha1": "^1.1.1",
        "sqlite": "^3.0.3",
        "sqlite3": "^5.1.7",
        "squel": "^5.12.0",
        "stream-buffers": "^3.0.1",
        "wait-for-event": "^1.0.0",
        "zippy": "0.0.3"
    },
    "devDependencies": {
