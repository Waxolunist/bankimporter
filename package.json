        "bulma": "0.6.2",
        "crossroads": "^0.12.2",
        "del": "^5",
        "fast-csv": "^2.4.1",
        "font-awesome": "^4.7.0",
        "gulp": "^4",
        "gulp-babel": "^8.0.0",
        "gulp-gzip": "^1.4.2",
        "gulp-newer": "^1.4.0",
        "gulp-pug": "^5.0.0",
        "gulp-sass": "^5.1.0",
        "gulp-sourcemaps": "^2.6.5",
        "gulp-uglify": "^3.0.0",
        "hasher": "^1.2.0",
        "jquery": "^3.4.1",
